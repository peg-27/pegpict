{
  "id": "/pegpict/",
  "name": "PEG PICT",
  "short_name": "PEG PICT",
  "description": "多機能画像編集アプリ",
  "start_url": "/pegpict/",
  "scope": "/pegpict/",
  "display": "standalone",
  "background_color": "#181818",
  "theme_color": "#181818",
  "icons": [
    {
      "src": "/pegpict/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pegpict/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "share_target": {
    "action": "/pegpict/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "image",
          "accept": ["image/jpeg", "image/png", "image/gif", "image/webp"]
        }
      ]
    }
  }
}